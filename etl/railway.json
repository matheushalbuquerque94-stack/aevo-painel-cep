{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": ["python311"]
        },
        "install": {
          "cmds": [
            "pip install --upgrade pip",
            "pip install -r ../requirements.txt"
          ]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "python cron_runner.py",
    "restartPolicyType": "NEVER",
    "cronSchedule": "0 5 * * *"
  }
}
