# Template das variaveis de ambiente.
# Copie como .env e preencha com valores reais. NAO commite o .env.
# No Railway, defina cada uma destas variaveis no dashboard (Project Variables).

# ── Supabase (banco do painel) ──────────────────────────────────────────
SUPABASE_HOST=db.XXXXXXXXXXXX.supabase.co
SUPABASE_PORT=5432
SUPABASE_DB=postgres
SUPABASE_USER=postgres
SUPABASE_PASSWORD=<senha-do-postgres-supabase>
SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
SUPABASE_REGION=us-east-1
SUPABASE_PUBLISHABLE_KEY=<sb_publishable_xxxxx>

# ── AEVO Postgres (leitura readonly de plant_plant, pvsyst_data, etc) ───
AEVO_HOST=shinkansen.proxy.rlwy.net
AEVO_PORT=18796
AEVO_DB=railway
AEVO_USER=powerbi_readonly_user
AEVO_PASSWORD=<senha-aevo>

# ── ETL config ──────────────────────────────────────────────────────────
ETL_MONTHS_BACK=1
TZ=America/Sao_Paulo
